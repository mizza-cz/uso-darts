<!DOCTYPE html>
<html lang="cs-CZ">
  <head>
    <meta charset="utf-8" />
    <title>{{ title }} - {{ project }}</title>
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, shrink-to-fit=no"
    />
    <meta name="format-detection" content="telephone=no" />

    <!--****** Favicon ******-->
    <!--****** Fonts ******-->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Rethink+Sans:ital,wght@0,400..800;1,400..800&display=swap"
      rel="stylesheet"
    />
    <!--****** Styles  ******-->
    <link rel="preload" href="css/styles.css" as="style" />
    <link rel="stylesheet" media="screen, handheld" href="css/styles.css" />
    <link rel="stylesheet" media="print" href="css/prints.css" />
    <link rel="stylesheet" type="text/css" href="css/cookie-consent.css" />
    <!--****** Styles  ******-->

    <!--****** Scripts  ******-->
    <link
      rel="preload"
      href="https://code.jquery.com/jquery-3.6.0.min.js"
      as="script"
      crossorigin
    />
    <link
      rel="preload"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"
      as="script"
      crossorigin
    />
    <link rel="preload" href="js/scripts.js" as="script" />
    <!-- ****** scripts ****** -->
  </head>
  <body>
    <div class="base">
      {% block main %}{% endblock %} {% include
      "@components/partnersSlider/partnersSlider.twig" %} {% include
      "@components/footer/footer.twig" %}
    </div>
    <script
      defer
      src="https://code.jquery.com/jquery-3.6.0.min.js"
      integrity="sha256-/xUj+3OJU5yExlq6GSYGSHk7tPXikynS7ogEvDej/m4="
      crossorigin="anonymous"
    ></script>
    <script
      defer
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-ka7Sk0Gln4gmtz2MlQnikT1wXgYsOg+OMhuP+IlRH9sENBO0LRn5q+8nbTov4+1p"
      crossorigin="anonymous"
    ></script>
    <script src="js/cookie-consent-config.js"></script>
    <script src="js/cookie-consent.js"></script>
    <script defer src="js/scripts.js"></script>
  </body>
</html>
