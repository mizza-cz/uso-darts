<div class="px-lg-10 p-6 bg-gray">
  <h2 class="h5 text-primary mb-4">Kontaktujte nás</h2>
  <form class="contactsForm">
    <div class="row g-3 mb-4">
      <div class="col-lg-3">
        <label class="form-label" for="name">Jméno a příjmení:</label>
      </div>
      <div class="col-lg-9">
        <input class="form-control w-100" type="text" id="name" name="name" />
      </div>
      <div class="col-lg-3">
        <label class="form-label" for="mail">E-mail:</label>
      </div>
      <div class="col-lg-9">
        <input class="form-control w-100" type="email" id="mail" name="mail" />
      </div>
      <div class="col-lg-3">
        <label class="form-label" for="message">Obsah zprávy:</label>
      </div>
      <div class="col-lg-9">
        <textarea
          class="form-control w-100"
          name="message"
          id="message"
        ></textarea>
      </div>
    </div>
    <div
      class="d-flex align-items-center justify-content-between flex-wrap gap-4"
    >
      <label class="consent-checkbox">
        <input type="checkbox" />
        <span class="consent-checkbox__box">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6 12.5l4 4 8-9" />
          </svg>
        </span>

        <span class="text-base-sm">
          Souhlasím se
          <a href="#">zpracováním osobních údajů</a>
        </span>
      </label>
      <button type="submit" class="button-secondary">
        Odeslat zprávu {% include "@images/chevron-right.svg" %}
      </button>
    </div>
  </form>
  <div class="alert alert-success mt-6" role="alert">
    Vaše zpráva byla úspěšně odeslána. Děkujeme.
  </div>
</div>
