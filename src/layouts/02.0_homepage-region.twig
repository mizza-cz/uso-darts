{% extends "@components/base/base.twig" %} {% set title = "02.0_homepage-region"
%} {% block main %} {% include "@components/header/header-region.twig" %}
<main class="main" aria-label="Hlavní obsah">
  <div class="bg-gray pt-6 pb-3 mb-lg-10 mb-8">
    <div class="container">
      <div
        class="d-md-flex align-items-md-center justify-content-between gap-3"
      >
        <h1 class="h6 text-secondary pb-3">Středočeský kraj</h1>
        <ul
          class="d-flex align-items-center gap-lg-6 gap-4 overflow-x-scroll space-nowrap pb-3"
        >
          <li>
            <a class="h6 hover-outline text-primary" href="#">Termínovka</a>
          </li>
          <li>
            <a class="h6 hover-outline text-primary" href="#">Žebříčky</a>
          </li>
          <li>
            <a class="h6 hover-outline text-primary" href="#">Turnaje</a>
          </li>
          <li>
            <a class="h6 hover-outline text-primary" href="#"
              >Soutěže družstev</a
            >
          </li>
          <li>
            <a class="h6 hover-outline text-primary" href="#">Informace</a>
          </li>
        </ul>
      </div>
    </div>
  </div>
  {% include "@components/hero/hero.twig" %}

  <div class="mb-10">
    <div class="container">
      <a class="d-block w-100" href="#">
        <img
          class="w-100 object-fit-cover"
          src="images/content/pub.webp"
          alt="pub"
          loading="lazy"
        />
      </a>
    </div>
  </div>

  <div class="mb-10">
    <div class="container">
      <div class="row g-xl-6 g-4">
        <div class="col-xl-6">
          <div class="bg-gray p-2">
            <div class="bg-white">
              <div
                class="py-6 px-md-8 px-4 d-flex flex-wrap justify-content-between align-items-center gap-4 border-bottom-gray-2"
              >
                <h3 class="h4">Severozápadní konference</h3>
                <a href="#" class="button-secondary">
                  Kompletní tabulka {% include "@images/chevron-right.svg" %}
                </a>
              </div>
              {% include "@components/tableConference/tableConference.twig" %}
            </div>
          </div>
        </div>
        <div class="col-xl-6">
          <div class="bg-gray p-2">
            <div class="bg-white">
              <div
                class="py-6 px-md-8 px-4 d-flex flex-wrap justify-content-between align-items-center gap-4 border-bottom-gray-2"
              >
                <h3 class="h4">Středovýchodní konference</h3>
                <a href="#" class="button-secondary">
                  Kompletní tabulka {% include "@images/chevron-right.svg" %}
                </a>
              </div>
              {% include "@components/tableConference/tableConference.twig" %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  {% include "@components/rankingBoard/rankingBoard.twig" %}
</main>
  {% endblock %}
