{% extends "@components/base/base.twig" %} {% set title = "01.0_homepage" %} {%
block main %} {% include "@components/header/header.twig" %}
<main class="main" aria-label="Hlavní obsah">
  {% include "@components/hero/hero.twig" %}

  <div class="mb-10">
    <div class="container">
      <a class="d-block w-100" href="#">
        <img
          class="w-100 object-fit-cover"
          src="images/content/pub.webp"
          alt="pub"
          loading="lazy"
        />
      </a>
    </div>
  </div>

  <div class="mb-10">
    <div class="container">
      <div class="row g-xl-6 g-4">
        <div class="col-xl-6">
          <div class="bg-gray p-2">
            <div class="bg-white">
              <div
                class="py-6 px-md-8 px-4 d-flex flex-wrap justify-content-between align-items-center gap-4 border-bottom-gray-2"
              >
                <h3 class="h4 text-primary">Severozápadní konference</h3>
                <a href="#" class="button-secondary">
                  Kompletní tabulka {% include "@images/chevron-right.svg" %}
                </a>
              </div>
              {% include "@components/tableConference/tableConference.twig" %}
            </div>
          </div>
        </div>
        <div class="col-xl-6">
          <div class="bg-gray p-2">
            <div class="bg-white">
              <div
                class="py-6 px-md-8 px-4 d-flex flex-wrap justify-content-between align-items-center gap-4 border-bottom-gray-2"
              >
                <h3 class="h4 text-primary">Středovýchodní konference</h3>
                <a href="#" class="button-secondary">
                  Kompletní tabulka {% include "@images/chevron-right.svg" %}
                </a>
              </div>
              {% include "@components/tableConference/tableConference.twig" %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  {% include "@components/rankingBoard/rankingBoard.twig" %}
</main>
 {% endblock %}
