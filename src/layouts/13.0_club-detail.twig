                      <td>A</td>
                    </tr>
                    <tr>
                      <td class="fw-bold ps-xxl-10">Klub:</td>
                      <td>
                        <a href="#" class="text-secondary"
                          >Sgt. Pepik's Band Praha</a
                        >
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>

      <h3 class="h4 text-primary mb-6">Soupiska klubu</h3>
      <div class="table-responsive mb-10">
        <table class="table">
          <thead>
            <tr>
              <th>Hráč</th>
              <th style="width: 164px">Registrační číslo</th>
              <th>Obec</th>
              <th style="width: 160px">GDPR souhlas</th>
              <th>Poznámka</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>
                <div class="d-flex align-items-center gap-3">
                  <div class="ps-md-3 pe-lg-7 pe-4">
                    <img
                      class="rounded-circle object-fit-cover object-position-top bg-gray"
                      width="80px"
                      height="80px"
                      src="images/content/no-player.png"
                      alt="avatar"
                    />
                  </div>
                  <a class="fw-bold text-secondary" href="#">
                    Hoffmann Martin
                  </a>
                </div>
              </td>
              <td>CZE000022</td>
              <td>Hořice na Šumavě</td>
              <td>Udělen</td>
              <td>–</td>
