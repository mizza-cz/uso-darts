              class="text-secondary"
              data-bs-toggle="modal"
              data-bs-target="#modalPlace"
              href="#"
            >
              DK Žďár nad Sázavou, Dolní 183/30
            </a>
          </div>
        </div>
      </div>
    </div>
    <div class="container">
      <div class="row g-6">
        <div class="col-xl-6">
          <div class="playerDetail">
            <h2 class="playerDetail__title h4">
              <div class="text-tertiary">Předseda klubu:</div>
              Jan Šipkařský
            </h2>
            <div class="playerDetail__inner">
              <div class="playerDetail__img">
                <img src="images/content/player.png" alt="avatar" />
              </div>
              <div class="playerDetail__info">
                <table class="table">
                  <tbody>
                    <tr>
                      <td class="fw-bold ps-xxl-10">Registrační číslo:</td>
                      <td>CZE000022</td>
                    </tr>
                    <tr>
                      <td class="fw-bold ps-xxl-10">Obec:</td>
                      <td>Říčany</td>
                    </tr>
                    <tr>
                      <td class="fw-bold ps-xxl-10">Kategorie:</td>
                      <td>A</td>
                    </tr>
                    <tr>
                      <td class="fw-bold ps-xxl-10">Klub:</td>
                      <td>
                        <a href="#" class="text-secondary"
                          >Sgt. Pepik's Band Praha</a
                        >
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
        <div class="col-xl-6">
          <div class="playerDetail">
            <h2 class="playerDetail__title h4">
              <div class="text-tertiary">Vedoucí družstva:</div>
              Jan Šipkařský
