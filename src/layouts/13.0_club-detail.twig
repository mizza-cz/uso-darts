              <th style="width: 240px" colspan="3" class="text-center">Legy</th>
            </tr>
            <tr>
              <th style="width: 80px" class="text-center">%</th>
              <th style="width: 80px" class="text-center">C</th>
              <th style="width: 80px" class="text-center">O</th>
              <th style="width: 80px" class="text-center">V</th>
              <th style="width: 80px" class="text-center">%</th>
              <th style="width: 80px" class="text-center">O</th>
