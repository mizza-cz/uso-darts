      <div class="table-responsive mb-10">
        <table class="table">
          <thead>
            <tr>
              <th style="width: 80px" rowspan="2">Pořadí</th>
              <th rowspan="2" class="text-start">Hráč</th>
              <th style="width: 80px" class="text-center" rowspan="2">LKH</th>
